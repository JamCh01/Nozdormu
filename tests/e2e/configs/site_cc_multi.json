{
  "site_id": "cc-multi",
  "enabled": true,
  "domains": ["cc-multi.cdn.jam114514.me"],
  "origins": [
    {
      "id": "origin-1",
      "host": "127.0.0.1",
      "port": 8081,
      "weight": 10,
      "protocol": "http"
    }
  ],
  "waf": { "enabled": false },
  "cc": {
    "enabled": true,
    "default_rate": 100,
    "default_window": 60,
    "default_block_duration": 30,
    "default_action": "block",
    "rules": [
      {
        "path": "/api/login",
        "rate": 2,
        "window": 60,
        "block_duration": 30,
        "action": "block",
        "key_type": "ip_path"
      },
      {
        "path": "/api/data",
        "rate": 50,
        "window": 60,
        "block_duration": 30,
        "action": "log",
        "key_type": "ip_url"
      }
    ]
  },
  "cache": { "enabled": false },
  "compression": { "enabled": false }
}

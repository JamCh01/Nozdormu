{
  "openapi": "3.1.0",
  "info": {
    "title": "Nozdormu CDN Admin API",
    "description": "Management API for the Nozdormu CDN reverse proxy. All endpoints are served on the proxy port under the `/_admin/` prefix and require Bearer token authentication configured via etcd `{prefix}/global/security`.",
    "version": "0.3.0",
    "contact": {
      "name": "Nozdormu CDN"
    }
  },
  "servers": [
    {
      "url": "http://localhost:6188/_admin",
      "description": "Local development"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/reload": {
      "post": {
        "operationId": "reloadConfig",
        "summary": "Reload configuration",
        "description": "Trigger a full configuration reload from etcd. Returns the new revision number and loaded site count.",
        "tags": ["Config"],
        "responses": {
          "200": {
            "description": "Configuration reloaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "message": { "type": "string" },
                    "revision": { "type": "integer", "format": "int64" },
                    "sites_loaded": { "type": "integer" }
                  },
                  "required": ["status", "message", "revision", "sites_loaded"]
                }
              }
            }
          },
          "500": {
            "description": "Reload failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/ssl/clear-cache": {
      "post": {
        "operationId": "clearSslCache",
        "summary": "Clear SSL certificate cache",
        "description": "Clears the in-memory SSL certificate cache, forcing re-reads from storage on next TLS handshake.",
        "tags": ["SSL"],
        "responses": {
          "200": {
            "description": "SSL cache cleared",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "message": { "type": "string" }
                  },
                  "required": ["status", "message"]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/site/{id}": {
      "get": {
        "operationId": "getSiteConfig",
        "summary": "Get site configuration summary",
        "description": "Returns a summary of the specified site's configuration including enabled features.",
        "tags": ["Sites"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Site identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Site configuration summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SiteConfigSummary" }
              }
            }
          },
          "404": {
            "description": "Site not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/upstream/health": {
      "get": {
        "operationId": "getUpstreamHealth",
        "summary": "Get upstream health status",
        "description": "Returns health status for every origin across all configured sites, including active/passive check results.",
        "tags": ["Upstream"],
        "responses": {
          "200": {
            "description": "Upstream health data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "origins": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/OriginHealth" }
                    }
                  },
                  "required": ["origins"]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/upstream/health/{site_id}/{origin_id}": {
      "put": {
        "operationId": "setUpstreamHealth",
        "summary": "Override origin health status",
        "description": "Manually set the health status of a specific origin. Useful for maintenance windows or emergency failover.",
        "tags": ["Upstream"],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Site identifier"
          },
          {
            "name": "origin_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Origin identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "healthy": { "type": "boolean", "description": "Target health status" }
                },
                "required": ["healthy"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Health status updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "site_id": { "type": "string" },
                    "origin_id": { "type": "string" },
                    "healthy": { "type": "boolean" }
                  },
                  "required": ["status", "site_id", "origin_id", "healthy"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body or path",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/cc/blocked": {
      "get": {
        "operationId": "getCcBlocked",
        "summary": "List CC-blocked IPs",
        "description": "Returns currently blocked IPs from the CC rate limiter. Note: currently returns an empty list as moka Cache does not support iteration.",
        "tags": ["CC"],
        "responses": {
          "200": {
            "description": "Blocked IP list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "blocked": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "note": { "type": "string" }
                  },
                  "required": ["blocked"]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/cache/purge": {
      "post": {
        "operationId": "purgeCache",
        "summary": "Purge cache entries",
        "description": "Purge by exact URL (synchronous), by entire site (asynchronous background task), or by cache tag (synchronous). The request body `type` field determines the variant.",
        "tags": ["Cache"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/PurgeUrlRequest" },
                  { "$ref": "#/components/schemas/PurgeSiteRequest" },
                  { "$ref": "#/components/schemas/PurgeTagRequest" }
                ],
                "discriminator": {
                  "propertyName": "type",
                  "mapping": {
                    "url": "#/components/schemas/PurgeUrlRequest",
                    "site": "#/components/schemas/PurgeSiteRequest",
                    "tag": "#/components/schemas/PurgeTagRequest"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "URL or tag purge completed",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "status": { "type": "string", "enum": ["ok"] },
                        "purge_type": { "type": "string", "enum": ["url"] },
                        "site_id": { "type": "string" },
                        "cache_key": { "type": "string" },
                        "keys_deleted": { "type": "integer" }
                      },
                      "required": ["status", "purge_type", "site_id", "cache_key", "keys_deleted"]
                    },
                    {
                      "type": "object",
                      "properties": {
                        "status": { "type": "string", "enum": ["ok"] },
                        "purge_type": { "type": "string", "enum": ["tag"] },
                        "site_id": { "type": "string" },
                        "tag": { "type": "string" },
                        "keys_deleted": { "type": "integer" }
                      },
                      "required": ["status", "purge_type", "site_id", "tag", "keys_deleted"]
                    }
                  ]
                }
              }
            }
          },
          "202": {
            "description": "Site purge accepted (running in background)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["accepted"] },
                    "purge_type": { "type": "string", "enum": ["site"] },
                    "site_id": { "type": "string" },
                    "task_id": { "type": "string", "format": "uuid" }
                  },
                  "required": ["status", "purge_type", "site_id", "task_id"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request (bad body, invalid site_id, invalid host/path, invalid tag)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Site not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "409": {
            "description": "A purge is already running for this site",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Purge operation failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/cache/purge/status/{task_id}": {
      "get": {
        "operationId": "getPurgeStatus",
        "summary": "Get purge task status",
        "description": "Returns the status of a background site-purge task by its task ID (UUID returned in the 202 response).",
        "tags": ["Cache"],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Purge task ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Purge task status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PurgeTaskStatus" }
              }
            }
          },
          "404": {
            "description": "Task not found (may have been auto-evicted after 1 hour)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/cache/purge/status": {
      "get": {
        "operationId": "listPurgeTasks",
        "summary": "List all purge tasks",
        "description": "Returns all tracked purge tasks. Completed tasks are auto-evicted after 1 hour.",
        "tags": ["Cache"],
        "responses": {
          "200": {
            "description": "List of purge tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tasks": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/PurgeTaskStatus" }
                    }
                  },
                  "required": ["tasks"]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/cache/warm": {
      "post": {
        "operationId": "warmCache",
        "summary": "Start cache warming",
        "description": "Submit a list of URLs to pre-fetch from origin and store in cache. Runs as an asynchronous background task with concurrency limit of 10. Maximum 1000 URLs per request. Already-cached URLs are skipped.",
        "tags": ["Cache"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WarmRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Warm task accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["accepted"] },
                    "task_id": { "type": "string", "format": "uuid" },
                    "site_id": { "type": "string" },
                    "urls_count": { "type": "integer" }
                  },
                  "required": ["status", "task_id", "site_id", "urls_count"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request (bad body, empty URLs, too many URLs, invalid site_id)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Site not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/cache/warm/status/{task_id}": {
      "get": {
        "operationId": "getWarmStatus",
        "summary": "Get warm task status",
        "description": "Returns the status of a background cache-warm task by its task ID.",
        "tags": ["Cache"],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Warm task ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Warm task status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WarmTaskStatus" }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/cache/warm/status": {
      "get": {
        "operationId": "listWarmTasks",
        "summary": "List all warm tasks",
        "description": "Returns all tracked warm tasks. Completed tasks are auto-evicted after 1 hour.",
        "tags": ["Cache"],
        "responses": {
          "200": {
            "description": "List of warm tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tasks": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/WarmTaskStatus" }
                    }
                  },
                  "required": ["tasks"]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/config/history/{site_id}": {
      "get": {
        "operationId": "listConfigVersions",
        "summary": "List config version history",
        "description": "Returns version history for a site configuration, newest first. Each entry includes version number, timestamp, etcd revision, and change type.",
        "tags": ["Config"],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Site identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Version history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "site_id": { "type": "string" },
                    "versions": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ConfigVersionSummary" }
                    }
                  },
                  "required": ["site_id", "versions"]
                }
              }
            }
          },
          "400": { "description": "Invalid site_id", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "description": "etcd error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/config/history/{site_id}/{version}": {
      "get": {
        "operationId": "getConfigVersion",
        "summary": "Get config version detail",
        "description": "Returns a specific version snapshot including the full site configuration body.",
        "tags": ["Config"],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Site identifier"
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "uint64", "minimum": 1 },
            "description": "Version number"
          }
        ],
        "responses": {
          "200": {
            "description": "Version snapshot",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConfigVersionSnapshot" }
              }
            }
          },
          "400": { "description": "Invalid parameters", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "description": "Version not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "500": { "description": "etcd error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/config/rollback/{site_id}/{version}": {
      "post": {
        "operationId": "rollbackConfig",
        "summary": "Rollback site config to a previous version",
        "description": "Reads a historical version snapshot and writes its config back to the live site key in etcd. The normal etcd watch mechanism detects the change and updates the running proxy. A new version snapshot with change_type 'rollback' is created.",
        "tags": ["Config"],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Site identifier"
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "uint64", "minimum": 1 },
            "description": "Version number to rollback to"
          }
        ],
        "responses": {
          "200": {
            "description": "Rollback successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "message": { "type": "string" },
                    "site_id": { "type": "string" },
                    "rolled_back_to": { "type": "integer", "format": "uint64" },
                    "new_version": { "type": "integer", "format": "uint64" }
                  },
                  "required": ["status", "message", "site_id", "rolled_back_to", "new_version"]
                }
              }
            }
          },
          "400": { "description": "Invalid parameters", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "description": "Version not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "500": { "description": "Rollback failed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/log/status": {
      "get": {
        "operationId": "getLogStatus",
        "summary": "Get current log backend status",
        "description": "Returns the active log backend type and configuration summary.",
        "tags": ["Logging"],
        "responses": {
          "200": {
            "description": "Log backend status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "backend": { "type": "string", "description": "Active backend type (redis, kafka, rabbitmq, nats, pulsar, disabled)" },
                    "config": { "type": "object", "description": "Backend-specific configuration summary (sensitive fields redacted)" }
                  },
                  "required": ["backend"]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/webhook/events": {
      "get": {
        "operationId": "webhookListEvents",
        "summary": "List recent webhook delivery attempts",
        "description": "Returns recent webhook delivery attempts across all sites, sorted by creation time (most recent first). Entries are auto-evicted after 1 hour.",
        "tags": ["Webhook"],
        "responses": {
          "200": {
            "description": "List of webhook delivery attempts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deliveries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/WebhookDeliveryStatus" }
                    }
                  },
                  "required": ["deliveries"]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/webhook/test/{site_id}": {
      "post": {
        "operationId": "webhookTest",
        "summary": "Send a test webhook event",
        "description": "Dispatches a test webhook event to all URLs configured in the specified site's webhook config. Returns 400 if webhooks are not enabled for the site.",
        "tags": ["Webhook"],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Site ID to send the test webhook for"
          }
        ],
        "responses": {
          "200": {
            "description": "Test webhook event dispatched",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "message": { "type": "string" },
                    "site_id": { "type": "string" },
                    "urls": { "type": "array", "items": { "type": "string" } }
                  },
                  "required": ["status", "message", "site_id", "urls"]
                }
              }
            }
          },
          "400": {
            "description": "Webhooks not configured for this site",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Site not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Admin API token configured in etcd `{prefix}/global/security` `admin_token` field"
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid Bearer token",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["error"] },
          "message": { "type": "string" }
        },
        "required": ["status", "message"]
      },
      "SiteConfigSummary": {
        "type": "object",
        "properties": {
          "site_id": { "type": "string" },
          "enabled": { "type": "boolean" },
          "domains": { "type": "array", "items": { "type": "string" } },
          "origins_count": { "type": "integer" },
          "waf_enabled": { "type": "boolean" },
          "cc_enabled": { "type": "boolean" },
          "cache_enabled": { "type": "boolean" }
        },
        "required": ["site_id", "enabled", "domains", "origins_count", "waf_enabled", "cc_enabled", "cache_enabled"]
      },
      "OriginHealth": {
        "type": "object",
        "properties": {
          "site_id": { "type": "string" },
          "origin_id": { "type": "string" },
          "host": { "type": "string" },
          "port": { "type": "integer" },
          "healthy": { "type": "boolean" },
          "backup": { "type": "boolean" },
          "enabled": { "type": "boolean" },
          "consecutive_successes": { "type": "integer" },
          "consecutive_failures": { "type": "integer" },
          "last_check_time": { "type": ["integer", "null"], "description": "Unix epoch seconds" },
          "last_check_success": { "type": ["boolean", "null"] }
        },
        "required": ["site_id", "origin_id", "host", "port", "healthy", "backup", "enabled", "consecutive_successes", "consecutive_failures"]
      },
      "PurgeUrlRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["url"] },
          "site_id": { "type": "string" },
          "host": { "type": "string" },
          "path": { "type": "string" },
          "query_string": { "type": ["string", "null"] },
          "sort_query_string": { "type": "boolean", "default": false },
          "vary_headers": {
            "type": "array",
            "items": {
              "type": "array",
              "prefixItems": [
                { "type": "string" },
                { "type": "string" }
              ],
              "minItems": 2,
              "maxItems": 2
            },
            "default": []
          }
        },
        "required": ["type", "site_id", "host", "path"]
      },
      "PurgeSiteRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["site"] },
          "site_id": { "type": "string" }
        },
        "required": ["type", "site_id"]
      },
      "PurgeTagRequest": {
        "type": "object",
        "description": "Purge all cache entries matching a cache tag. Tags are parsed from origin Surrogate-Key / Cache-Tag response headers.",
        "properties": {
          "type": { "type": "string", "enum": ["tag"] },
          "site_id": { "type": "string" },
          "tag": { "type": "string", "maxLength": 128, "description": "Cache tag to purge (from Surrogate-Key / Cache-Tag headers)" }
        },
        "required": ["type", "site_id", "tag"]
      },
      "PurgeTaskStatus": {
        "type": "object",
        "properties": {
          "task_id": { "type": "string", "format": "uuid" },
          "site_id": { "type": "string" },
          "status": { "type": "string", "enum": ["running", "completed", "failed"] },
          "keys_deleted": { "type": "integer", "format": "int64" },
          "started_at": { "type": "integer", "format": "int64", "description": "Unix timestamp" },
          "completed_at": { "type": ["integer", "null"], "format": "int64", "description": "Unix timestamp, omitted when null" },
          "error": { "type": ["string", "null"], "description": "Error message, omitted when null" }
        },
        "required": ["task_id", "site_id", "status", "keys_deleted", "started_at"]
      },
      "WarmRequest": {
        "type": "object",
        "description": "Request to pre-warm cache by fetching URLs from origin.",
        "properties": {
          "site_id": { "type": "string" },
          "urls": {
            "type": "array",
            "maxItems": 1000,
            "items": { "$ref": "#/components/schemas/WarmUrl" }
          }
        },
        "required": ["site_id", "urls"]
      },
      "WarmUrl": {
        "type": "object",
        "properties": {
          "host": { "type": "string", "description": "Host header for the request" },
          "path": { "type": "string", "description": "URL path (must start with /)" },
          "query_string": { "type": ["string", "null"], "description": "Optional query string" }
        },
        "required": ["host", "path"]
      },
      "WarmTaskStatus": {
        "type": "object",
        "properties": {
          "task_id": { "type": "string", "format": "uuid" },
          "site_id": { "type": "string" },
          "status": { "type": "string", "enum": ["running", "completed", "failed"] },
          "urls_total": { "type": "integer" },
          "urls_completed": { "type": "integer" },
          "urls_failed": { "type": "integer" },
          "started_at": { "type": "integer", "format": "int64", "description": "Unix timestamp" },
          "completed_at": { "type": ["integer", "null"], "format": "int64", "description": "Unix timestamp, omitted when null" },
          "error": { "type": ["string", "null"], "description": "Error message, omitted when null" }
        },
        "required": ["task_id", "site_id", "status", "urls_total", "urls_completed", "urls_failed", "started_at"]
      },
      "ConfigChangeType": {
        "type": "string",
        "enum": ["created", "updated", "deleted", "rollback"],
        "description": "The type of change that produced this config version"
      },
      "ConfigVersionSummary": {
        "type": "object",
        "description": "Summary of a config version (without the full config body)",
        "properties": {
          "version": { "type": "integer", "format": "uint64", "minimum": 1 },
          "site_id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time", "description": "RFC 3339 UTC timestamp" },
          "etcd_revision": { "type": "integer", "format": "int64" },
          "change_type": { "$ref": "#/components/schemas/ConfigChangeType" }
        },
        "required": ["version", "site_id", "timestamp", "etcd_revision", "change_type"]
      },
      "ConfigVersionSnapshot": {
        "type": "object",
        "description": "Full versioned snapshot of a site config, including the config body",
        "properties": {
          "version": { "type": "integer", "format": "uint64", "minimum": 1 },
          "site_id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time", "description": "RFC 3339 UTC timestamp" },
          "etcd_revision": { "type": "integer", "format": "int64" },
          "change_type": { "$ref": "#/components/schemas/ConfigChangeType" },
          "config": { "type": "object", "description": "The full SiteConfig JSON at this version" }
        },
        "required": ["version", "site_id", "timestamp", "etcd_revision", "change_type", "config"]
      },
      "WebhookDeliveryStatus": {
        "type": "object",
        "description": "Status of a single webhook delivery attempt",
        "properties": {
          "delivery_id": { "type": "string", "format": "uuid", "description": "Unique delivery ID" },
          "event_type": { "type": "string", "description": "Event type (cert_renewal_success, cert_renewal_failure, health_status_change, cache_purge_completed, test)" },
          "url": { "type": "string", "format": "uri", "description": "Target webhook URL" },
          "status": { "type": "string", "enum": ["pending", "delivered", "failed"], "description": "Delivery state" },
          "attempts": { "type": "integer", "description": "Number of delivery attempts made" },
          "last_status_code": { "type": ["integer", "null"], "description": "HTTP status code from last attempt" },
          "last_error": { "type": ["string", "null"], "description": "Error message from last failed attempt" },
          "created_at": { "type": "integer", "format": "int64", "description": "Unix epoch seconds when the delivery was created" },
          "completed_at": { "type": ["integer", "null"], "format": "int64", "description": "Unix epoch seconds when the delivery completed (success or final failure)" }
        },
        "required": ["delivery_id", "event_type", "url", "status", "attempts", "created_at"]
      }
    }
  },
  "tags": [
    { "name": "Config", "description": "Configuration management" },
    { "name": "SSL", "description": "SSL/TLS certificate management" },
    { "name": "Sites", "description": "Site configuration queries" },
    { "name": "Upstream", "description": "Upstream origin health management" },
    { "name": "CC", "description": "CC rate limiting status" },
    { "name": "Cache", "description": "Cache purge, warm, and management operations" },
    { "name": "Logging", "description": "Log backend status" },
    { "name": "Webhook", "description": "Webhook notification delivery status and testing" }
  ]
}

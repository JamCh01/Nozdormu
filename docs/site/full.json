{
  "_doc": "完整站点配置 — 所有功能组合示例",

  "site_id": "production-site",
  "enabled": true,
  "port": 80,
  "domains": ["www.example.com", "example.com", "*.cdn.example.com"],
  "target_labels": ["region:asia", "tier:edge"],

  "origins": [
    {
      "id": "primary-1",
      "host": "backend-1.example.com",
      "port": 443,
      "weight": 60,
      "protocol": "https",
      "backup": false,
      "enabled": true,
      "sni": "backend-1.example.com",
      "verify_ssl": true
    },
    {
      "id": "primary-2",
      "host": "backend-2.example.com",
      "port": 443,
      "weight": 40,
      "protocol": "https",
      "backup": false,
      "enabled": true,
      "verify_ssl": true
    },
    {
      "id": "backup-1",
      "host": "fallback.example.com",
      "port": 80,
      "weight": 10,
      "protocol": "http",
      "backup": true,
      "enabled": true
    }
  ],

  "load_balancer": {
    "algorithm": "round_robin",
    "retries": 2,
    "health_check": {
      "enabled": true,
      "type": "http",
      "path": "/health",
      "interval": 10,
      "timeout": 5,
      "healthy_threshold": 2,
      "unhealthy_threshold": 3
    },
    "adaptive_weight": {
      "_enabled": "是否启用自适应权重调整（基于 P99 延迟和错误率自动调权）",
      "enabled": true,
      "_window_size": "滑动窗口大小（采样数），默认 100",
      "window_size": 100,
      "_latency_threshold_ms": "P99 延迟阈值（毫秒），超过此值开始惩罚权重",
      "latency_threshold_ms": 500.0,
      "_error_threshold": "错误率阈值（0.0-1.0），超过此值开始惩罚权重",
      "error_threshold": 0.1
    }
  },

  "protocol": {
    "force_https": {
      "enable": true,
      "redirect_code": 301,
      "https_port": null,
      "exclude_paths": ["/health", "/.well-known/"]
    },
    "http2": true,
    "websocket": { "enable": true },
    "sse": { "enable": false },
    "grpc": { "enabled": false }
  },

  "ssl": {
    "enabled": true,
    "type": "acme",
    "acme_email": "admin@example.com"
  },

  "cache": {
    "enabled": true,
    "default_ttl": 3600,
    "max_size": 104857600,
    "sort_query_string": true,
    "vary_headers": [],
    "cache_authorized": false,
    "cache_cookies": false,
    "rules": [
      { "type": "extension", "match": ["js", "css", "png", "jpg", "webp", "woff2", "svg"], "ttl": 86400 },
      { "type": "path", "match": "/api", "ttl": 0 },
      { "type": "path", "match": "/static", "ttl": 604800 }
    ]
  },

  "waf": {
    "enabled": true,
    "mode": "block",
    "rules": {
      "ip_whitelist": ["203.0.113.0/24"],
      "ip_blacklist": ["198.51.100.0/24"],
      "asn_blacklist": [],
      "country_whitelist": ["US", "JP", "CN", "DE", "GB", "KR", "SG"],
      "country_blacklist": [],
      "region_blacklist": {},
      "continent_blacklist": []
    },
    "body_inspection": {
      "enabled": true,
      "max_body_size": 26214400,
      "allowed_content_types": ["image/*", "application/pdf", "video/*"],
      "blocked_content_types": ["application/x-executable"],
      "inspect_methods": ["POST", "PUT", "PATCH"]
    }
  },

  "cc": {
    "enabled": true,
    "default_rate": 100,
    "default_window": 60,
    "default_block_duration": 600,
    "default_action": "block",
    "rules": [
      { "path": "/api/login", "rate": 5, "window": 60, "block_duration": 1800, "action": "challenge", "key_type": "ip" },
      { "path": "/api/register", "rate": 3, "window": 300, "block_duration": 3600, "action": "block", "key_type": "ip" }
    ]
  },

  "headers": {
    "request": [
      { "action": "set", "name": "X-Forwarded-Proto", "value": "https" },
      { "action": "add", "name": "X-Request-Source", "value": "nozdormu" }
    ],
    "response": [
      { "action": "set", "name": "X-Frame-Options", "value": "DENY" },
      { "action": "set", "name": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
      { "action": "set", "name": "X-Content-Type-Options", "value": "nosniff" },
      { "action": "set", "name": "X-Client-IP", "value": "${client_ip}" },
      { "action": "remove", "name": "X-Powered-By" }
    ]
  },

  "domain_redirect": null,
  "url_redirect_rules": [],

  "timeouts": {
    "connect": 5,
    "send": 30,
    "read": 30
  },

  "compression": {
    "enabled": true,
    "algorithms": ["zstd", "brotli", "gzip"],
    "level": 6,
    "min_size": 256,
    "compressible_types": [
      "text/*",
      "application/json",
      "application/javascript",
      "application/xml",
      "image/svg+xml"
    ]
  },

  "image_optimization": {
    "enabled": true,
    "formats": ["avif", "webp"],
    "default_quality": 80,
    "max_width": 4096,
    "max_height": 4096,
    "max_input_size": 52428800,
    "optimizable_types": ["image/jpeg", "image/png", "image/gif", "image/bmp", "image/tiff"]
  },

  "range": {
    "enabled": true,
    "chunk_size": 4194304
  },

  "streaming": {
    "auth": {
      "enabled": true,
      "auth_type": "b",
      "auth_key": "your-hmac-secret-key",
      "expire_time": 1800
    },
    "dynamic_packaging": {
      "enabled": true,
      "segment_duration": 6.0,
      "max_mp4_size": 2147483648,
      "ll_hls": {
        "_enabled": "启用 LL-HLS（Low-Latency HLS）部分分片",
        "enabled": true,
        "_part_duration": "部分分片目标时长（秒），默认 0.5s",
        "part_duration": 0.5
      }
    },
    "prefetch": {
      "enabled": true,
      "prefetch_count": 3,
      "concurrency_limit": 4
    }
  },

  "error_pages": {
    "403": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>403</title></head><body><h1>403 Forbidden</h1></body></html>",
    "404": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>404</title></head><body><h1>404 Not Found</h1></body></html>",
    "500": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>500</title></head><body><h1>500 Internal Server Error</h1></body></html>"
  },

  "webhook": {
    "enabled": true,
    "urls": ["https://alerts.example.com/cdn-webhook"],
    "secret": "your_hmac_secret",
    "timeout_secs": 10,
    "max_retries": 3
  }
}

{
  "_doc": "负载均衡 — 随机（random）",
  "_desc": "随机选择一个健康的源站。适合无状态服务，简单且分布均匀。",

  "site_id": "lb-random",
  "enabled": true,
  "port": 80,
  "domains": ["random.example.com"],
  "origins": [
    { "id": "node-1", "host": "10.0.3.1", "port": 8080, "weight": 10, "protocol": "http" },
    { "id": "node-2", "host": "10.0.3.2", "port": 8080, "weight": 10, "protocol": "http" },
    { "id": "node-3", "host": "10.0.3.3", "port": 8080, "weight": 10, "protocol": "http" },
    { "id": "node-4", "host": "10.0.3.4", "port": 8080, "weight": 10, "protocol": "http" }
  ],
  "load_balancer": {
    "algorithm": "random",
    "retries": 3,
    "_adaptive_weight": "自适应权重同样适用于 random，高延迟/高错误率的源站被选中概率降低",
    "adaptive_weight": {
      "enabled": false,
      "window_size": 100,
      "latency_threshold_ms": 500.0,
      "error_threshold": 0.1
    }
  }
}

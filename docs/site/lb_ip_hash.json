{
  "_doc": "负载均衡 — IP 哈希（ip_hash，Ketama 一致性哈希环）",
  "_desc": "基于一致性哈希环（Ketama）根据客户端 IP 选择源站。同一 IP 始终路由到同一后端，且源站增减时仅 1/N 的请求重新映射。适合有状态会话和缓存亲和场景。",

  "site_id": "lb-ip-hash",
  "enabled": true,
  "port": 80,
  "domains": ["sticky.example.com"],
  "origins": [
    { "id": "app-1", "host": "10.0.2.1", "port": 3000, "weight": 10, "protocol": "http" },
    { "id": "app-2", "host": "10.0.2.2", "port": 3000, "weight": 10, "protocol": "http" },
    { "id": "app-3", "host": "10.0.2.3", "port": 3000, "weight": 10, "protocol": "http" }
  ],
  "load_balancer": {
    "algorithm": "ip_hash",
    "retries": 1,
    "health_check": {
      "enabled": true,
      "type": "tcp",
      "interval": 5,
      "timeout": 3,
      "healthy_threshold": 1,
      "unhealthy_threshold": 2
    },
    "_adaptive_weight": "自适应权重同样适用于 ip_hash，惩罚高延迟/高错误率的源站",
    "adaptive_weight": {
      "enabled": false,
      "window_size": 100,
      "latency_threshold_ms": 500.0,
      "error_threshold": 0.1
    }
  }
}

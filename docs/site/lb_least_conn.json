{
  "_doc": "负载均衡 — 最少连接（least_conn）",
  "_desc": "将请求分配给当前活跃连接数最少的源站。连接数相同时，优先选择权重更高的源站。适合请求处理时间差异较大的场景。",

  "site_id": "lb-least-conn",
  "enabled": true,
  "port": 80,
  "domains": ["lc.example.com"],
  "origins": [
    { "id": "web-1", "host": "10.0.1.1", "port": 8080, "weight": 10, "protocol": "http" },
    { "id": "web-2", "host": "10.0.1.2", "port": 8080, "weight": 10, "protocol": "http" },
    { "id": "web-3", "host": "10.0.1.3", "port": 8080, "weight": 5, "protocol": "http" }
  ],
  "load_balancer": {
    "algorithm": "least_conn",
    "_retries": "请求失败后重试次数（0-10），会自动跳过失败的源站",
    "retries": 2,
    "health_check": {
      "enabled": true,
      "type": "http",
      "path": "/health",
      "interval": 10,
      "timeout": 5,
      "healthy_threshold": 2,
      "unhealthy_threshold": 3
    },
    "_adaptive_weight": "自适应权重同样适用于 least_conn，在连接数相同时优先选择有效权重更高的源站",
    "adaptive_weight": {
      "enabled": false,
      "window_size": 100,
      "latency_threshold_ms": 500.0,
      "error_threshold": 0.1
    }
  }
}
